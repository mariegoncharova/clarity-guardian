{
  "name": "clarity-guardian",
  "version": "2.0.0",
  "description": "Task clarity analytics and reporting tool for GitHub, Jira, and Yandex Tracker.",
  "main": "dist/analyze.js",
  "types": "dist/analyze.d.ts",
  "type": "commonjs",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "analyze": "npm run build --silent && node dist/analyze.js",
    "generate:test-checklist": "npm run build --silent && node dist/generate-test-checklist.js",
    "sync:github": "npm run build --silent && node dist/sync-github.js",
    "sync:jira": "npm run build --silent && node dist/sync-jira.js",
    "fetch:yandex": "npm run build --silent && node dist/yandex-tracker.js",
    "retro": "npm run build --silent && node dist/retro-report.js",
    "retro:demo": "npm run retro -- --input data/demo_tasks.json --output reports/retro_report.md",
    "v2:demo": "npm run build --silent && node dist/v2-report.js --demo --out-dir reports/demo",
    "v2:report": "npm run build --silent && node dist/v2-report.js",
    "build:smoke": "rm -rf .smoke-dist && tsc -p tsconfig.scripts.json",
    "smoke": "npm run build --silent && npm run build:smoke --silent && node .smoke-dist/smoke-test.js",
    "check": "tsc --noEmit",
    "verify": "npm run check && npm run build && npm run smoke && npm run v2:demo && npm run retro:demo && npm audit --audit-level=moderate"
  },
  "keywords": [
    "github-actions",
    "qa",
    "devops",
    "automation",
    "openai",
    "checklist",
    "typescript"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.9.3"
  }
}
